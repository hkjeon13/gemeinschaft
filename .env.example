# Server host
SERVICE_HOST=127.0.0.1

# Docker Compose overrides (optional)
# These are used by docker-compose.yml to avoid collisions with local dev values.
COMPOSE_SERVICE_HOST=0.0.0.0
COMPOSE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gemeinschaft
COMPOSE_POSTGRES_USER=postgres
COMPOSE_POSTGRES_PASSWORD=postgres
COMPOSE_POSTGRES_DB=gemeinschaft
COMPOSE_POSTGRES_PORT=5432
COMPOSE_OBJECT_STORAGE_PROVIDER=local_fs
COMPOSE_OBJECT_STORAGE_ROOT=/data/object_storage
COMPOSE_EXPORT_STORAGE_DIR=/data/exports
COMPOSE_AGENT_RUNTIME_BASE_URL=http://agent_runtime:8002
COMPOSE_CONVERSATION_ORCHESTRATOR_BASE_URL=http://conversation_orchestrator:8001

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gemeinschaft
DB_POOL_ENABLED=true
DB_POOL_REQUIRE=false
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT_SECONDS=10

# Object storage
OBJECT_STORAGE_PROVIDER=local_fs
OBJECT_STORAGE_ROOT=.local/object_storage
EXPORT_STORAGE_DIR=.local/exports

# Ingestion chunking
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_CHARS=120

# Embedding job
EMBEDDING_MODEL=hash-v1
EMBEDDING_DIM=128

# Topic clustering
TOPIC_SIMILARITY_THRESHOLD=0.82

# Agent runtime routing
AGENT_AI_1_MODEL=gpt-4o-mini
AGENT_AI_2_MODEL=gpt-4.1-mini
AGENT_DEFAULT_MODEL=gpt-4.1-mini
AGENT_AI_1_PROVIDER=stub
AGENT_AI_2_PROVIDER=stub
AGENT_DEFAULT_PROVIDER=stub
AGENT_RUNTIME_BASE_URL=http://127.0.0.1:8002
AGENT_RUNTIME_PROVIDER=stub
AGENT_RUNTIME_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
CONVERSATION_ORCHESTRATOR_BASE_URL=http://127.0.0.1:8001

# Service ports
API_GATEWAY_PORT=8000
CONVERSATION_ORCHESTRATOR_PORT=8001
AGENT_RUNTIME_PORT=8002
DATA_INGESTION_PORT=8003
TOPIC_PIPELINE_PORT=8004
EXPORT_SERVICE_PORT=8005
SCHEDULER_PORT=8006

# Internal service auth (optional but recommended for non-local environments)
# When set, requests to non-health endpoints must include:
#   x-internal-api-token: <INTERNAL_API_TOKEN>
# Optional scope/role headers:
#   x-internal-role: admin|operator|viewer|system
#   x-auth-tenant-id: <tenant-uuid>
#   x-auth-workspace-id: <workspace-uuid>
INTERNAL_API_TOKEN=

# Scheduler -> Conversation Orchestrator outbound auth (optional override)
# If empty, scheduler will reuse INTERNAL_API_TOKEN for outbound calls.
ORCHESTRATOR_INTERNAL_API_TOKEN=
SCHEDULER_INTERNAL_ROLE=system
SCHEDULER_INTERNAL_PRINCIPAL_ID=scheduler-service
ORCHESTRATOR_HTTP_TIMEOUT_SECONDS=10
ORCHESTRATOR_HTTP_MAX_RETRIES=0
ORCHESTRATOR_HTTP_RETRY_BACKOFF_SECONDS=0.2
