# Server host
SERVICE_HOST=127.0.0.1

# Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gemeinschaft

# Object storage
OBJECT_STORAGE_PROVIDER=local_fs
OBJECT_STORAGE_ROOT=.local/object_storage

# Ingestion chunking
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_CHARS=120

# Embedding job
EMBEDDING_MODEL=hash-v1
EMBEDDING_DIM=128

# Service ports
API_GATEWAY_PORT=8000
CONVERSATION_ORCHESTRATOR_PORT=8001
AGENT_RUNTIME_PORT=8002
DATA_INGESTION_PORT=8003
TOPIC_PIPELINE_PORT=8004
EXPORT_SERVICE_PORT=8005
