# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
FRONTEND_PORT=10015

# Auth/JWT
JWT_ALGORITHM=RS256
JWT_ISSUER=gemeinschaft-api
JWT_AUDIENCE=gemeinschaft-clients
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14
JWT_ACTIVE_KID=k2026_02
JWT_PRIVATE_KEYS_FILE=/run/secrets/jwt_private_keys.json
JWT_PUBLIC_KEYS_FILE=/run/secrets/jwt_public_keys.json
# Fallback only (not recommended in production)
# JWT_PRIVATE_KEYS_JSON={"k2026_01":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----","k2026_02":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"}
# JWT_PUBLIC_KEYS_JSON={"k2026_01":"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----","k2026_02":"-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"}

# Login rate limit
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_WINDOW_SECONDS=60
AUTH_LOGIN_BLOCK_SECONDS=300
AUTH_TRUST_PROXY_HEADERS=false
SECURITY_STATE_BACKEND=postgres

# User credentials (bcrypt hashes recommended)
# Example hash generation:
# python -c "import bcrypt; print(bcrypt.hashpw(b'psyche-pass', bcrypt.gensalt()).decode())"
AUTH_USERS_FILE=/run/secrets/auth_users.json
# Optional JSON source (escape `$` as `$$` when using docker-compose env interpolation):
# AUTH_USERS_JSON={"psyche":{"password_hash":"$$2b$$12$$replace_me","role":"admin"}}
# Optional explicit backend: postgres|memory (default: postgres when DATABASE_ENABLED=true)
# AUTH_USER_STORE_BACKEND=postgres

# Authorization policy (scope/tenant/resource)
# AUTHZ_POLICIES_JSON={"conversation:list":{"required_scopes":["conversation:read"],"enforce_tenant":true},"conversation:get":{"required_scopes":["conversation:read"],"enforce_tenant":true},"conversation:create":{"required_scopes":["conversation:write"],"enforce_tenant":true},"admin:user:list":{"required_roles":["admin"],"enforce_tenant":true},"admin:user:create":{"required_roles":["admin"],"enforce_tenant":true},"admin:user:update":{"required_roles":["admin"],"enforce_tenant":true},"admin:user:delete":{"required_roles":["admin"],"enforce_tenant":true}}
AUTH_DEFAULT_TENANT=default
AUTH_DEFAULT_SCOPES=conversation:read conversation:write
AUTH_ALLOW_PLAINTEXT_PASSWORDS=false

# Postgres
DATABASE_ENABLED=true
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gemeinschaft
POSTGRES_USER=gemeinschaft
POSTGRES_PASSWORD=change-me
# Optional override:
# DATABASE_URL=postgresql://gemeinschaft:change-me@postgres:5432/gemeinschaft
